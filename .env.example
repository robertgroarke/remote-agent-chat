# ── Relay Server ──────────────────────────────────────────────────────────────

# Port the relay listens on inside the container (leave as 3500)
PORT=3500

# Your public URL — set this to your Cloudflare Tunnel hostname
# e.g. https://agents.yourdomain.com
# Used for Google OAuth callback and WebSocket CORS checks
PUBLIC_URL=https://agents.yourdomain.com

# Google OAuth2 — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <PUBLIC_URL>/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Only this Google account can log in
ALLOWED_EMAIL=you@gmail.com

# Strong random secret for Express session cookies (run: openssl rand -hex 32)
SESSION_SECRET=changeme

# Strong random secret for JWT tokens issued to the Android/PWA app (openssl rand -hex 32)
JWT_SECRET=changeme

# Secret the agent proxy must send to connect (openssl rand -hex 32)
# Set this same value in agent-proxy/.env as PROXY_SECRET
PROXY_SECRET=changeme

# ── Agent Proxy helpers ───────────────────────────────────────────────────────

# IP and port of your relay server on the LAN (used by proxy_restart_lock.py)
# Only needed if running the proxy on the same LAN as the relay
RELAY_IP=192.168.1.x
RELAY_PORT=3500

# Rescue relay URL (used by rescue-proxy.js if main relay is down)
RESCUE_RELAY_URL=ws://192.168.1.x:3501/proxy-ws

# ── SSH Deploy (optional — only needed if using tools/rebuild_unraid_docker.py) ─

# SSH host of your server (hostname or IP)
DEPLOY_HOST=your-server-hostname
DEPLOY_USER=root
DEPLOY_PASSWORD=your-ssh-password

# Remote path where relay files are synced
DEPLOY_RELAY_PATH=/mnt/user/appdata/agent-relay

# Docker network name on the remote server
DEPLOY_DOCKER_NETWORK=bridge

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────

# Token from: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → Docker
# Configure the tunnel public hostname → service: http://relay:3500
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
